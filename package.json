{
  "name": "typed-event-contract",
  "version": "1.0.1",
  "description": "A fully typed, cross-runtime event contract system for TypeScript. Define events once as a type map and get full inference at every emit site and listener.",
  "keywords": [
    "typescript",
    "events",
    "event-bus",
    "event-emitter",
    "typed",
    "websocket",
    "worker",
    "cross-runtime"
  ],
  "author": "Ashley <ashley@nullworks.dev>",
  "license": "GPL-3.0-or-later",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "lint": "eslint .",
    "benchmark": "jiti benchmarks/benchmark.ts"
  },
  "dependencies": {
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.2",
    "@types/ws": "^8.18.1",
    "eslint": "^10.4.1",
    "expect-type": "^1.3.0",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@10.33.0"
}
